{
  "name": "timbre-ai-voice-synthesis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "bunx --bun prisma generate",
    "db:generate": "bunx --bun prisma generate",
    "db:push": "bunx --bun prisma db push",
    "db:migrate": "bunx --bun prisma generate && bunx --bun prisma migrate dev --name init",
    "db:studio": "bunx --bun prisma studio",
    "db:reset": "bunx --bun prisma migrate reset",
    "bucket:setup": "bun scripts/bucket-setup.ts",
    "bucket:teardown": "bun scripts/bucket-teardown.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@base-ui/react": "^1.3.0",
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@iconify/react": "^6.0.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@react-email/components": "^1.0.11",
    "@tanstack/react-form": "^1.28.6",
    "@types/recordrtc": "^5.6.15",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "locale-codes": "^1.3.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "nuqs": "2.8.8",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "3.8.0",
    "recordrtc": "^5.6.2",
    "resend": "6.9.3",
    "shadcn": "^4.1.2",
    "simplex-noise": "^4.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.1.0",
    "vaul": "^1.1.2",
    "wavesurfer.js": "^7.12.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
